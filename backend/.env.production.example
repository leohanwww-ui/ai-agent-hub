# ────────────────────────────────────────────
# AI Agent Hub - 生产环境配置
# 复制此文件为 .env.production 并填写真实值
# ────────────────────────────────────────────

# ── 后端 ───────────────────────────────────
PORT=3000
NODE_ENV=production

# ── MySQL ──────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=ai_agent_hub
DB_USER=aiagent
DB_PASSWORD=请改成强密码_至少16位

# ── JWT ────────────────────────────────────
# 用 openssl rand -hex 48 生成
JWT_SECRET=请用随机字符串替换
JWT_EXPIRES_IN=7d

# ── 前端地址（CORS 白名单，部署后改为你的域名）──
FRONTEND_URL=https://你的域名.com
